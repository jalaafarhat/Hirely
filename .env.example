# Database
DATABASE_URL=postgresql://hirely:hirely@localhost:5433/hirely

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# AI (Google Gemini)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Job Search (SerpAPI for aggregated job sources)
SERPAPI_API_KEY=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Hirely <noreply@yourdomain.com>

# App (local dev)
APP_URL=http://localhost:4200
API_URL=http://localhost:3000

# Production example:
# APP_URL=https://hirelycareeragent.com
# API_URL=https://hirelycareeragent.com
# CORS_ORIGINS=https://www.hirelycareeragent.com
NODE_ENV=development
PORT=3000

# Agent
JOB_MATCH_THRESHOLD=75
AGENT_CRON=0 8 * * *
